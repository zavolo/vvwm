<Page
    x:Class="VlessVPN.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#FF1A1A2E">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="VLESS VPN"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0,8,0,16"/>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="UriBox"
                     Grid.Column="0"
                     PlaceholderText="vless://uuid@host:port?..."
                     FontSize="13"
                     TextWrapping="Wrap"
                     MaxHeight="80"
                     AcceptsReturn="False"/>
            <Button x:Name="PasteBtn"
                    Grid.Column="1"
                    Content="&#xE77F;"
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="18"
                    Margin="8,0,0,0"
                    VerticalAlignment="Stretch"
                    Click="PasteBtn_Click"/>
            <Button x:Name="FileBtn"
                    Grid.Column="2"
                    Content="&#xE8E5;"
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="18"
                    Margin="8,0,0,0"
                    VerticalAlignment="Stretch"
                    Click="FileBtn_Click"/>
        </Grid>

        <StackPanel Grid.Row="2" Margin="0,0,0,16">
            <TextBlock x:Name="StatusText"
                       Text="Disconnected"
                       FontSize="16"
                       Foreground="#FF888888"
                       HorizontalAlignment="Center"/>
            <TextBlock x:Name="ConfigInfo"
                       Text=""
                       FontSize="12"
                       Foreground="#FF666666"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <Button x:Name="ConnectBtn"
                Grid.Row="3"
                Content="CONNECT"
                FontSize="18"
                FontWeight="Bold"
                HorizontalAlignment="Stretch"
                Height="56"
                Margin="0,0,0,16"
                Background="#FF4CAF50"
                Foreground="White"
                Click="ConnectBtn_Click"/>

        <TextBox x:Name="LogBox"
                 Grid.Row="4"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 FontSize="11"
                 FontFamily="Consolas"
                 Background="#FF0D0D1A"
                 Foreground="#FF00FF00"
                 BorderThickness="0"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
    </Grid>
</Page>